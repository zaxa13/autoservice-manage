# Database
DATABASE_URL=postgresql://user:password@localhost:5432/autoservice_db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ЮKassa
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# SMS (пример для sms.ru)
SMS_API_KEY=your-sms-api-key
SMS_SENDER=Autoservice

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=your-email@gmail.com

# Поставщики запчастей (пример)
PARTS_SUPPLIER_API_KEY=your-supplier-api-key
PARTS_SUPPLIER_API_URL=https://api.supplier.com

# ГИБДД API (пример)
GIBDD_API_KEY=your-gibdd-api-key
GIBDD_API_URL=https://api.gibdd.ru

# Environment
ENVIRONMENT=development
DEBUG=True

